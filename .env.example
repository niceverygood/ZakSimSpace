# ─── 작심스페이스 환경 변수 ───
# 모든 키가 비어 있어도 사이트는 정상 동작합니다 (관련 기능만 placeholder 처리).

# Kakao Map JS SDK — 지점 상세 페이지의 실 지도 활성화
# https://developers.kakao.com/console/app → 앱 키 → JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Vercel Web Analytics 활성화 (Vercel 배포 시) — "1" 로 설정하면 켜짐
NEXT_PUBLIC_VERCEL_ANALYTICS=

# ─── NicePay 결제 ───
# 가맹점 콘솔: https://manager.nicepay.co.kr
NICEPAY_MID=
NICEPAY_MERCHANT_KEY=
NICEPAY_SID=
NEXT_PUBLIC_NICEPAY_MID=
# "true" → 실 결제 모드. 기본 false (테스트).
NEXT_PUBLIC_NICEPAY_LIVE=false
# NicePay 콜백 redirect 기준 URL — 배포 환경에서 실 도메인으로
NEXT_PUBLIC_SITE_URL=http://localhost:3737

# ─── Supabase ───
# 프로젝트 콘솔: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ─── 예정 통합 (현재 미사용) ───
# KAKAO_OAUTH_CLIENT_ID=
# NAVER_OAUTH_CLIENT_ID=
# ALIGO_API_KEY=
