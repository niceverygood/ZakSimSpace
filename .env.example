# ─── 작심스페이스 환경 변수 ───
# 모든 키가 비어 있어도 사이트는 정상 동작합니다 (관련 기능만 placeholder 처리).

# Kakao Map JS SDK — 지점 상세 페이지의 실 지도 활성화
# https://developers.kakao.com/console/app → 앱 키 → JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Vercel Web Analytics 활성화 (Vercel 배포 시) — "1" 로 설정하면 켜짐
NEXT_PUBLIC_VERCEL_ANALYTICS=

# ─── 예정 통합 (현재 미사용) ───
# TOSS_PAYMENTS_CLIENT_KEY=
# PORTONE_STORE_ID=
# KAKAO_OAUTH_CLIENT_ID=
# NAVER_OAUTH_CLIENT_ID=
# DATABASE_URL=
# ALIGO_API_KEY=
